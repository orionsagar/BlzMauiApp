@page "/salesdetails/{id}/{PageNumber}/{PageSize}"

@using BlzMauiApp.Services
@using BlzMauiApp.Services.Data;
@using BlzMauiApp.Services.DataService

<InnerHeader Title="Invoice Details List" BackUrl="/saleslist" />

<div class="page-content-wrapper py-3">
    <div class="container">

        @{
            foreach (var item in invoiceList.SDVMS)
            {
                <h6>Product Code: @item.ProductCode</h6>
                <h6>Name: @item.ProductName</h6>
                <table class="table table-bordered caption-top">
                    <thead>
                        <tr>
                            <th>Qty</th>
                            <th>B. Qty</th>
                            <th>Total Qty</th>
                            <th>Unit</th>
                            <th>Price</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@item.Quantity</td>
                            <td>@item.BonousQty</td>
                            <td>@item.TotalQty</td>
                            <td>@item.UnitName</td>
                            <td>@item.Price</td>
                            <td>@item.SubTotal</td>
                        </tr>
                    </tbody>
                </table>
                <div style="border-top: 1px solid #ebebeb;"></div>
            }
        }


        @*<div class="card product-details-card mb-3 direction-rtl">
            <div class="card-body">
            </div>
        </div>*@
    </div>
</div>

@code {

    [Parameter]
    public string id { get; set; }

    [Parameter]
    public string PageNumber { get; set; }

    [Parameter]
    public string PageSize { get; set; }

    public SalesInvoice invoiceList;

    #region API
    private readonly APIDataService _apiServices = new APIDataService();
    private readonly LoginDatabase loginDatabase = new LoginDatabase();
    #endregion

    protected override void OnInitialized()
    {
        base.OnInitialized();

        LoadInvoice();
    }

    protected void LoadInvoice()
    {
        var getList = Task.Run(async () => await _apiServices.GetAllInvoice("", Convert.ToInt32(PageNumber), Convert.ToInt32(PageSize))).Result;
        invoiceList = getList.items.Where(s => s.InvID == Convert.ToInt32(id)).FirstOrDefault();
    }
}
