                RepresentativeID = uf.rid;
                CompID = uf.compID;
            }
        }

        GetBranch();

        // customers = dbContext.Customers.ToList();

        products = await _apiServices.GetAllProduct();
        selectedProduct = products.Take(0).ToList();



    }


