    {
        if (BranchID != null)
        {
            var allBranch = await _apiServices.GetBranchs(BranchID);
            if (allBranch != null)
            {
                //BranchList.Append(new SelectListItem
                //    {
                //        Value = "0",
                //        Text = "Select Branch"
                //    });

                BranchList = allBranch.ToList();
                BranchList1 = allBranch.ToList();
                //foreach (var item in allBranch)
                //{
                //    BranchList.Add(new SelectListItem
                //        {
                //            Value = item.Value,
                //            Text = item.Text
                //        });
                //}

                GetCustomerByMr();
            }
        }
        else
        {
            txtInvoiceNo = "";
        }


        //BranchList.Add(new SelectListItem
        //{
        //    Value = "1",
        //    Text = "Chittagong"
        //});
        //BranchList.Add(new SelectListItem
        //{
        //    Value = "2",
        //    Text = "Dhaka"
        //});

    }

    void OnChange(string value, string name)
    {
        //console.Log($"{name} value changed to {value}");
    }

    void OnChange(object value, string name)
    {
        var str = value is IEnumerable<object> ? string.Join(", ", (IEnumerable<object>)value) : value;

        //console.Log($"{name} value changed to {str}");
    }

    void OnChangeCustomer(object value, string name)
    {
        var str = value is IEnumerable<object> ? string.Join(", ", (IEnumerable<object>)value) : value;


    }

    void OnChange(DateTime? value, string name, string format)
    {
        //console.Log($"{name} value changed to {value?.ToString(format)}");
    }


    // For Modal Show and Hide Start
    bool showModal = false;

    void ModalShow()
    {
        showModal = true;
    }
    void ModalCancel()
    {
        showModal = false;
    }

    void ModalOk()
    {
        Console.WriteLine("Modal ok");
        showModal = false;
    }
    //End


    //IJSObjectReference JsObjectRef { get; set; }
    protected override async Task OnAfterRenderAsync(bool first)
    {
        //JsObjectRef = await js.InvokeAsync<IJSObjectReference>("import", "/js/ForModal.js");
        try
        {
            if (selectedProduct?.Any() == true)
            {
                var hasDup = productInfo.Any(x => x.ProductID == selectedProduct[0].ProductID);
                if (hasDup != true)
                {
                    var amt = (1 * Convert.ToDecimal(selectedProduct[0].MrpPrice));
                    productInfo.Add(
                    new ProductInfo
                        {
                            ProductID = Convert.ToInt32(selectedProduct[0].ProductID),
                            ProductCode = selectedProduct[0].ProductCode.ToString(),
                            ProductName = selectedProduct[0].ProductName.ToString(),
                            ProductType = selectedProduct[0].ProductType,
                            ProductPrice = Convert.ToDecimal(selectedProduct[0].MrpPrice),
                            Qty = 1,
                            BensQty = 0,
                            TotalQty = 1,
                            Barcode = selectedProduct[0].ProductCode.ToString(),
                            UnitID = Convert.ToInt32(selectedProduct[0].UnitID),
                            Unit = selectedProduct[0].Unit.ToString(),
                            Amount = Convert.ToDecimal(amt),
                            CurrentStock = selectedProduct[0].CurrentStock
                        });
            }
            
            //IsShowPopup = "modal fade";
            //IsStyleShowPopup = "style='display: none;'";
            //call the js function to close the modal
            //await JsObjectRef.InvokeVoidAsync("CloseModal", "#staticBackdrop");
        }
    }

