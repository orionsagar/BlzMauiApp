    /// <param name="value"></param>
    ///
    private void RemoveProduct(int i) => productInfo.RemoveAt(i);

    private void UpdateQty(int i, string value)
    {
        productInfo[i].Qty = Convert.ToInt32(value);
        var amt = (Convert.ToInt32(value) * Convert.ToDecimal(selectedProduct[0].MrpPrice));
        productInfo[i].Amount = amt;
    }

    private void UpdateBenQty(int i, string value)
    {
        productInfo[i].BensQty = Convert.ToInt32(value);
        var amt = (Convert.ToInt32(value) * Convert.ToDecimal(selectedProduct[0].MrpPrice));
        productInfo[i].Amount = amt;
    }

