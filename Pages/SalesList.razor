    protected void LoadPrevInvoice()
    {
        if (PreviousPage == "Yes")
        {
            if (CurrentPage > 1)
            {
                PageNumber = CurrentPage - 1;
            }
            else
            {
                PageNumber = CurrentPage;
            }

            spinner = true;
            Task.Delay(1);

            invoiceList = Task.Run(async () => await _apiServices.GetAllInvoice("", PageNumber, (int)PageSize)).Result;
            CurrentPage = invoiceList.currentPage;
            PreviousPage = invoiceList.previousPage;
            NextPage = invoiceList.nextPage;

            Task.Delay(1);
            spinner = false;

            if (NextPage == "Yes")
                btnNextDisable = false;
            else
                btnNextDisable = true;
        }
        else
        {
            btnPrevDisable = true;

            if (NextPage == "Yes")
                btnNextDisable = false;
            else
                btnNextDisable = true;
        }

        JS.InvokeVoidAsync("backToTop");
    }

    protected void LoadNextInvoice()
    {
        if (NextPage == "Yes")
        {
            if (CurrentPage >= 1)
            {
                if (TotalPage == CurrentPage)
                {
                    PageNumber = CurrentPage;
                }
                else
                {
                    CurrentPage += 1;
                    PageNumber += 1;
                }
            }
            else
            {
                PageNumber = CurrentPage;
            }

            spinner = true;
            Task.Delay(1);

            invoiceList = Task.Run(async () => await _apiServices.GetAllInvoice("", PageNumber, (int)PageSize)).Result;
            CurrentPage = invoiceList.currentPage;
            PreviousPage = invoiceList.previousPage;
            NextPage = invoiceList.nextPage;

            Task.Delay(1);
            spinner = false;


            if (PreviousPage == "Yes")
                btnPrevDisable = false;
            else
                btnPrevDisable = true;


        }
        else
        {
            btnNextDisable = true;

            if (PreviousPage == "Yes")
                btnPrevDisable = false;
            else
                btnPrevDisable = true;
        }

        JS.InvokeVoidAsync("backToTop");
    }

    public void GetBranch()
    {
        if (BranchID != null)
        {
            var allBranch = Task.Run(async () => await _apiServices.GetBranchs(BranchID)).Result;
            if (allBranch != null)
            {
                BranchList = allBranch.ToList();
            }
        }
    }

    void OnChangeBranch(object value, string name)
    {
        var str = value is IEnumerable<object> ? string.Join(", ", (IEnumerable<object>)value) : value;
        //txtInvoiceNo.DefaultIfEmpty();
        if (value is not null)
        {
            BranchID = value.ToString();
            GetZone(BranchID);
        }
    }

    public void GetZone(string BranchID)
    {
        if (BranchID != null)
        {
            var allZone = Task.Run(async () => await _apiServices.GetZone(BranchID)).Result;
            if (allZone != null)
            {
                ZoneList = allZone.ToList();
            }
        }
    }

    void OnChangeZone(object value, string name)
    {
        var str = value is IEnumerable<object> ? string.Join(", ", (IEnumerable<object>)value) : value;
        //txtInvoiceNo.DefaultIfEmpty();
        if (value is not null)
        {
            GetArea(value.ToString());
        }
    }

    public void GetArea(string ZoneID)
    {
        if (ZoneID != null)
        {
            var allArea = Task.Run(async () => await _apiServices.GetArea(ZoneID)).Result;
            if (allArea != null)
            {
                AreaList = allArea.ToList();
            }
        }
    }

    void OnChangeArea(object value, string name)
    {
        var str = value is IEnumerable<object> ? string.Join(", ", (IEnumerable<object>)value) : value;
        //txtInvoiceNo.DefaultIfEmpty();
        if (value is not null)
        {
            GetRepresentative(value.ToString(), BranchID);
            GetCustomer(value.ToString(), BranchID);
        }
    }

    public void GetRepresentative(string AreaID, string BranchID)
    {
        if (AreaID != null)
        {
            var allRepre = Task.Run(async () => await _apiServices.GetRepresentative(AreaID, BranchID)).Result;
            if (allRepre != null)
            {
                RepresentativeList = allRepre.ToList();
            }
        }
    }

    public void GetCustomer(string AreaID, string BranchID)
    {
        if (AreaID != null)
        {
            var allCus = Task.Run(async () => await _apiServices.GetCustomer(AreaID, BranchID)).Result;
            if (allCus != null)
            {
                CustomerList = allCus.ToList();
            }
        }
    }
