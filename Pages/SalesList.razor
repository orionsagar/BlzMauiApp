    <!-- Top Products-->
    <div class="top-products-area product-list-wrap">
        <div class="container">
            <div class="row g-3">

                @{
                    if (spinner == true)
                    {
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }

                    if (invoiceList != null)
                    {
                        foreach (var item in invoiceList.items)
                        {
                            <div class="col-12">
                                <div class="card single-product-card">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            @*<div class="card-side-img">
                                <a class="product-thumbnail d-block" href="#">
                                <img src="/image/bg-img/p1.jpg" alt="">
                                <!-- Badge -->
                                <span class="badge bg-primary">Sale</span>
                                </a>
                                </div>*@

                                            <div class="card-content ">
                                                <div style="width:80%;" class="float-start">
                                                    <!-- Product Thumbnail -->
                                                    <a class="product-title d-block text-truncate mt-0" href="/salesdetails/@item.InvID/@PageNumber/@PageSize">Inv No: @item.InvNo</a>
                                                    @{
                                                        DateTime d = Convert.ToDateTime(item.Saledate);
                                                        var nd = d.Day + "-" + (d.Month.ToString().Length == 1 ? "0" + d.Month.ToString() : d.Month.ToString()) + "-" + d.Year;
                                                    }
                                                    <a class="product-title d-block text-truncate mt-0" href="/salesdetails/@item.InvID/@PageNumber/@PageSize">Date: @nd</a>
                                                    <!-- Product Title -->
                                                    <a class="product-title d-block text-truncate mt-0" href="/salesdetails/@item.InvID/@PageNumber/@PageSize">Cus Name: @item.CustomerName</a>
                                                </div>
                                                <div style="width:20%;" class="float-end">
                                                    <a class="btn m-1 btn-sm btn-warning" href="javascript:;"><i class="bi bi-pencil-square"></i></a>
                                                    <a class="btn btn-sm btn-primary me-2" href="javascript:;"><i class="bi bi-file-earmark-pdf"></i>Print Pos</a>
                                                </div>
                                                <!-- Product Title -->
                                                @*<a class="product-title d-block text-truncate mt-0" href="#">Qty: </a>*@
                                                <!-- Product Price -->
                                                @*<p class="sale-price">Sub Total:  <span>Tk @item.MrpPrice</span></p>*@
                                                @*<p class="sale-price">Dis:  <span>Tk @item.MrpPrice</span></p>*@
                                                @*<p class="sale-price">Charge:  <span>Tk @item.MrpPrice</span></p>*@
                                                @*<p class="sale-price">Total:  <span>Tk @item.MrpPrice</span></p>*@

                                                <table class="table table-bordered">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col">Qty</th>
                                                            <th scope="col">Sub Total</th>
                                                            <th scope="col">Dis</th>
                                                            <th scope="col">Charge</th>
                                                            <th scope="col">Total</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <th scope="row">@item.TotalQty</th>
                                                            <th scope="row">@item.SubTotal</th>
                                                            <td>@item.DiscAmnt</td>
                                                            <td>@item.DelvCharge</td>
                                                            <td>@item.NetAmnt</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                                <!-- Add To Cart Button -->
                                                @*<a class="btn btn-danger btn-sm disabled" href="#">
                                    <i class="bi bi-cart-x me-1"></i>Out of Stock
                                    </a>*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                }

                <div style="height: 60px;"></div>
                <div class="footer">

                    @*<button class="btn btn-primary btn-back-to-top" @onclick="@LoadPrevInvoice" ><i class="bi bi-arrow-left"></i> Prev. Page</button>
                    <button class="btn btn-primary float-end btn-back-to-top" @onclick="@LoadNextInvoice"><i class="bi bi-arrow-right"></i> Next Page</button>*@

                    <RadzenButton id="btnPrev" Click=@(args => LoadPrevInvoice()) Disabled="@btnPrevDisable" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" class="btn-back-to-top backtotop"><i class="bi bi-arrow-left"></i> Prev. Page</RadzenButton>
                    <RadzenButton id="btnNext" Click=@(args => LoadNextInvoice()) Disabled="@btnNextDisable" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" class="float-end btn-back-to-top backtotop"><i class="bi bi-arrow-right"></i> Next Page</RadzenButton>
                </div>

            </div>
        </div>
    </div>
</div>
@*affanOffcanvas
//affanOffcanvsLabel*@
<!-- Offcanvas Start -->
<div class="offcanvas offcanvas-start" id="filterOffcanvas" data-bs-scroll="true" tabindex="-1"
     aria-labelledby="filterOffcanvsLabel">

    <button class="btn-close btn-close-black text-reset" type="button" data-bs-dismiss="offcanvas"
            aria-label="Close"></button>

    <div class="offcanvas-body p-0">
        <div class="sidenav-wrapper">
            <!-- Sidenav Profile -->
            @*<div class="sidenav-profile">
            <div class="sidenav-style1"></div>
            <!-- User Thumbnail -->
            <div class="user-profile">
            <img src="image/bg-img/2.jpg" alt="">
            </div>
            <!-- User Info -->
            </div>*@
            <div class="container">
                <div class="user-info">
                    <h5 class="user-name mb-0 mt-1">Filter</h5>
                </div>

                <!-- Sidenav Nav -->
                <ul class="sidenav-nav ps-0">
                    <li>
                        <div class="form-group">
                            <label>Branch</label>
                            <RadzenDropDown AllowClear="true"
                                            TValue="string"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            AllowFiltering="true"
                                            Class="w-100"
                                            Placeholder="Select Branch"
                                            Data=@BranchList
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Change=@(args => OnChangeBranch(args, "DropDown with placeholder")) />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>Zone</label>
                            <RadzenDropDown AllowClear="true"
                                            TValue="string"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            AllowFiltering="true"
                                            Class="w-100"
                                            Placeholder="Select Zone"
                                            Data=@ZoneList
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Change=@(args => OnChangeZone(args, "DropDown with placeholder")) />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>Area</label>
                            <RadzenDropDown AllowClear="true"
                                            TValue="string"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            AllowFiltering="true"
                                            Class="w-100"
                                            Placeholder="Select Area"
                                            Data=@AreaList
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Change=@(args => OnChangeArea(args, "DropDown with placeholder")) />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>Representative</label>
                            <RadzenDropDown AllowClear="true"
                                            TValue="string"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            AllowFiltering="true"
                                            Class="w-100"
                                            Placeholder="Select Representative"
                                            Data=@RepresentativeList
                                            TextProperty="Text"
                                            ValueProperty="Value" />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>Customer</label>
                            <RadzenDropDown AllowClear="true"
                                            TValue="string"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            AllowFiltering="true"
                                            Class="w-100"
                                            Placeholder="Select Customer"
                                            Data=@CustomerList
                                            TextProperty="Text"
                                            ValueProperty="Value" />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>From</label>
                            <RadzenDatePicker @bind-Value=@value DateFormat="d" Change=@(args => OnChange(args, "DatePicker", "MM/dd/yyyy")) Class="w-100" />
                        </div>
                    </li>
                    <li>
                        <div class="form-group">
                            <label>To</label>
                            <RadzenDatePicker @bind-Value=@value DateFormat="d" Change=@(args => OnChange(args, "DatePicker", "MM/dd/yyyy")) Class="w-100" />
                        </div>
                    </li>
                </ul>
            </div>

            <div class="container">
                <div style="border-top: 1px solid #ebebeb;"></div>
                <button class="btn btn-sm btn-secondary justify-content-center float-start" type="button">
                    Reset
                </button>
                <button class="btn btn-sm btn-primary justify-content-center float-end" type="button">
                    Apply
                </button>
            </div>


            <!-- Social Info -->
            <div class="social-info-wrap">

                @*<a href="#">
                //    <i class="bi bi-facebook"></i>
                //</a>
                //<a href="#">
                //    <i class="bi bi-twitter"></i>
                //</a>
                //<a href="#">
                //    <i class="bi bi-linkedin"></i>
                //</a>*@
            </div>

            <!-- Copyright Info -->
            @*<div class="copyright-info">
            <p>
            <span id="copyrightYear"></span>
            &copy; Made by <a href="#">Designing World</a>
            </p>
            </div>*@
        </div>
    </div>
</div>

