<InnerHeader Title="Invoice List" BackUrl="/home" hasBackUrl="false" />

<div class="page-content-wrapper py-3">
    <!-- Element Heading -->
    @*<div class="container">
    <div class="element-heading">
    <h6>All input field</h6>
    </div>
    </div>*@

